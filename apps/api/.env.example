DATABASE_URL=postgresql://rag:rag@localhost:5432/rag_kb
STORAGE_ROOT=../web/storage
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Opcional: cola Redis para indexación asíncrona (worker: `python -m app.worker`). Si está vacío, se usa BackgroundTasks.
REDIS_URL=

# Límites de subida (opcional; valores por defecto en app/config.py)
# MAX_UPLOAD_BYTES=20971520
# UPLOAD_ALLOWED_MIMES=application/pdf,text/plain,text/markdown,text/x-markdown,application/octet-stream
# MAX_DOCUMENTS_PER_KNOWLEDGE_BASE=200
# INDEX_QUEUE_CRED_TTL_SECONDS=900

# Opcional: claves solo en servidor cuando el cliente no envía X-API-Key.
OPENAI_API_KEY=
GOOGLE_API_KEY=
