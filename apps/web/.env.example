# PostgreSQL
# - App en el host + solo `db` en Docker: usa localhost
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag_kb
# - App en contenedor (`docker compose up web`): Compose inyecta DATABASE_URL con host `db`

# URL del FastAPI tal como la ve el **navegador** (si NEXT_PUBLIC_USE_RAG_PROXY=false).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# true = el cliente llama a `/api/rag-proxy/...` y la API key va en cookie httpOnly (requiere AI_SESSION_SECRET).
NEXT_PUBLIC_USE_RAG_PROXY=false

# URL del FastAPI como la ve el **servidor Next** al reenviar (híbrido: 127.0.0.1:8000; Docker: http://api:8000).
API_INTERNAL_URL=http://127.0.0.1:8000

# Cifrado de la cookie de sesión IA (mínimo 16 caracteres). Obligatorio si NEXT_PUBLIC_USE_RAG_PROXY=true.
AI_SESSION_SECRET=cambia_esto_minimo_16_caracteres
